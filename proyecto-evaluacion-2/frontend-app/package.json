{
  "name": "frontend-app",
  "version": "1.0.0",
  "description": "Módulo NPM reutilizable que implementa el patrón Factory para instanciar servicios de comunicación con el BFF",
  "main": "src/main/index.js",
  "scripts": {
    "start": "node src/main/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --coverageReporters=text --coverageReporters=lcov"
  },
  "keywords": ["factory-pattern", "bff-client", "design-patterns"],
  "author": "Integrante 1",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/main/**/*.js",
      "src/services/**/*.js",
      "src/components/**/*.js",
      "!src/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "coverageReporters": ["text", "lcov", "html"]
  }
}
